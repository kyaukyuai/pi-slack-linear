{
  "name": "pi-slack-linear",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slack to Linear task bot powered by pi-coding-agent",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "workgraph:health": "tsx scripts/workgraph-maintenance.ts health",
    "workgraph:snapshot": "tsx scripts/workgraph-maintenance.ts snapshot",
    "workgraph:compact": "tsx scripts/workgraph-maintenance.ts compact",
    "workgraph:recover": "tsx scripts/workgraph-maintenance.ts recover"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.58.3",
    "@mariozechner/pi-coding-agent": "0.58.3",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.0",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
